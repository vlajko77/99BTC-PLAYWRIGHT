{
  "name": "99btc-playwright",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke --project=chromium --retries=0",
    "test:full": "playwright test --project=chromium",
    "test:ci": "playwright test tests/regression --project=chromium",
    "test:visual": "playwright test tests/regression/visualRegression.spec.ts --project=chromium",
    "test:visual:update": "playwright test tests/regression/visualRegression.spec.ts --project=chromium --update-snapshots",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "lint": "eslint . --ext .ts,.js",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.9.1",
    "dotenv": "^16.0.0",
    "typescript": "^5.5.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0"
  }
}
