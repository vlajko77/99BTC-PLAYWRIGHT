# Copy this file to .env and fill in your values
# Never commit .env — it is gitignored

# WordPress admin credentials
WP_USERNAME=your-wp-admin@example.com
WP_PASSWORD=your-wp-password

# Base URL of the site under test
# Local:   https://99bitcoins.local
# Staging: https://staging.99bitcoins.com
PLAYWRIGHT_BASE_URL=https://staging.99bitcoins.com

# HTTP Basic Auth for staging (leave empty if not required)
STAGING_HTTP_USER=
STAGING_HTTP_PASS=
